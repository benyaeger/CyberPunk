# Langfuse observability — paste your keys from Langfuse UI → Settings → API Keys.
# Copy this file to `.env` (already gitignored) and fill in the values.
# Leave blank to disable tracing (the agent runs fine offline without them).
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# EU cloud (default): https://cloud.langfuse.com
# US cloud:           https://us.cloud.langfuse.com
# Self-hosted:        https://langfuse.your-domain.com
LANGFUSE_HOST=https://cloud.langfuse.com
